# BlindOracle — direnv config
# Run `direnv allow` after cloning

use node 22

export NODE_ENV="${NODE_ENV:-development}"

# Uncomment when compact compiler is installed locally:
# export COMPACT_HOME="$HOME/.compact"
# export PATH="$COMPACT_HOME/bin:$PATH"

# Midnight network config (undeployed by default)
export MIDNIGHT_NETWORK="undeployed"
