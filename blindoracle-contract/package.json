{
  "name": "blindoracle-contract",
  "version": "0.1.0",
  "private": true,
  "description": "BlindOracle Compact smart contracts and TypeScript bindings",
  "type": "module",
  "main": "dist/src/index.js",
  "module": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./managed": {
      "import": "./dist/src/managed/blind-oracle/contract/index.cjs",
      "types": "./dist/src/managed/blind-oracle/contract/index.d.cts"
    }
  },
  "scripts": {
    "compact": "compactc compile compact/blind-oracle.compact --output src/managed",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist src/managed",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-runtime": "3.1.0",
    "@midnight-ntwrk/midnight-js-contracts": "3.1.0",
    "@midnight-ntwrk/midnight-js-types": "3.1.0"
  },
  "devDependencies": {
    "typescript": "~5.7.0",
    "vitest": "^3.0.0"
  }
}
