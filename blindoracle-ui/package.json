{
  "name": "blindoracle-ui",
  "version": "0.1.0",
  "private": true,
  "description": "BlindOracle — React + Vite frontend",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5177",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview --port 5177",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .vite"
  },
  "dependencies": {
    "blindoracle-api": "*",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "@mui/material": "^6.2.0",
    "@mui/icons-material": "^6.2.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.0",
    "typescript": "~5.7.0",
    "vite": "^8.0.0"
  }
}
